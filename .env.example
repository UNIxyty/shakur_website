# =============================================================================
# SHAKUR — environment template. Copy to `.env` and fill in.
#
# `.env` is gitignored. Never commit real values.
# After changing any VITE_* var you must REBUILD, not just restart:
#   docker compose up -d --build
# (Vite bakes them into the JS bundle at build time.)
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Dashboard > Project Settings > API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# The "anon" / "public" key (a long JWT starting with eyJ...).
#
# This key is MEANT to be public — it ships inside the browser bundle. It is safe
# only because Row Level Security constrains what it can do. Do NOT paste the
# service_role key here: that one bypasses RLS entirely and would hand every
# visitor full write access to your database.
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Site mode FALLBACK. Since v4 the real switch is runtime: Settings ▸ Site
# settings persists site_settings.status, no rebuild needed, and signed-in
# admins always see the full site. This var only decides the mode for the very
# first paint and when Supabase is unconfigured ('live' or 'coming_soon'; a
# `shakur_site_mode=live` cookie still overrides to live). Build-time value —
# rebuild after changing.
VITE_SITE_MODE=live

# Canonical public origin, no trailing slash. Fills the <link rel="canonical">
# and og:url/og:image tags in index.html (%VITE_PUBLIC_BASE_URL% is replaced by
# Vite at build time — it MUST be set, or the literal placeholder ships).
# Baked in at build time — rebuild after changing.
VITE_PUBLIC_BASE_URL=https://shakurs.com

# -----------------------------------------------------------------------------
# Server API (compose service `api`) — SERVER-SIDE ONLY.
#
# None of these are VITE_* on purpose: VITE_ vars are baked into the public JS
# bundle, so putting a secret there publishes it to every visitor. These vars
# are only injected into the api container at runtime and never reach the
# browser. Changing them needs only a restart of `api`, not a web rebuild.
# -----------------------------------------------------------------------------

# Same project URL as VITE_SUPABASE_URL (no trailing slash).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# The service_role key (Dashboard > Project Settings > API). It BYPASSES Row
# Level Security entirely — that is exactly why the meetings table has no anon
# policies: attendee PII is only reachable through this server, which validates
# every request first. Safe here because the api container has no published
# ports (nginx proxies /api/ internally). NEVER put this in a VITE_ var and
# never commit it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# OpenAI — powers POST /api/ai/write ("Write with AI" in the admin).
# Missing key => endpoint answers 503 and the admin falls back to sample copy.
OPENAI_API_KEY=sk-YOUR-OPENAI-KEY

# Resend — transactional booking emails (emails/ templates).
# Missing key => bookings still work, emails are skipped (logged).
# RESEND_FROM must be a sender on a domain you verified in Resend.
RESEND_API_KEY=re_YOUR-RESEND-KEY
RESEND_FROM=SHAKUR <bookings@shakur.lv>

# Public origin of the site — used to build /booking/<token> and consultation
# email links. (Renamed from PUBLIC_URL in v3; the server still falls back to
# a legacy PUBLIC_URL value if this one is unset.)
PUBLIC_BASE_URL=https://shakurs.com

# Shown as the reply-to/help contact in booking emails.
SUPPORT_EMAIL=info@shakur.lv

# -----------------------------------------------------------------------------
# Cloudflare Tunnel — managed via CLI, no token needed here.
# One-time setup (see README):
#   cloudflared tunnel login
#   bash scripts/setup-tunnel.sh
# Credentials live in ./cloudflared/ (gitignored), mounted into the container.
# -----------------------------------------------------------------------------
