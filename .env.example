# =============================================================================
# SHAKUR — environment template. Copy to `.env` and fill in.
#
# `.env` is gitignored. Never commit real values.
# After changing any VITE_* var you must REBUILD, not just restart:
#   docker compose up -d --build
# (Vite bakes them into the JS bundle at build time.)
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Dashboard > Project Settings > API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# The "anon" / "public" key (a long JWT starting with eyJ...).
#
# This key is MEANT to be public — it ships inside the browser bundle. It is safe
# only because Row Level Security constrains what it can do. Do NOT paste the
# service_role key here: that one bypasses RLS entirely and would hand every
# visitor full write access to your database.
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# -----------------------------------------------------------------------------
# Cloudflare Tunnel — managed via CLI, no token needed here.
# One-time setup (see README):
#   cloudflared tunnel login
#   bash scripts/setup-tunnel.sh
# Credentials live in ./cloudflared/ (gitignored), mounted into the container.
# -----------------------------------------------------------------------------
